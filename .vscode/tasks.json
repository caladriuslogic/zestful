{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill-zestful",
      "type": "shell",
      "command": "pkill -x zestful; exit 0",
      "options": {
        "shell": {
          "executable": "/bin/sh",
          "args": ["-c"]
        }
      },
      "windows": {
        "command": "taskkill /F /IM zestful.exe 2>nul & exit 0",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
