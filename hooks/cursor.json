{
  "hooks": [
    {
      "event": "stop",
      "command": "zestful notify --agent \"cursor:$(basename $PWD)\" --message 'Waiting for your input'"
    },
    {
      "event": "start",
      "command": "zestful notify --agent \"cursor:$(basename $PWD)\" --message 'Working...' --severity info --no-push"
    }
  ]
}
